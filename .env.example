# QuantIAN — environment variable reference.
# Copy to `.env` and tweak as needed. Not all services honor every variable;
# see `shared/config/settings.py` for the loader.

# ======================================================================
# Overall runtime
# ======================================================================
APP_ENV=local                      # local | cloud
ENABLE_SERVICE_RUNTIME=true        # peers register + heartbeat when true
DEBUG=false

# ======================================================================
# Where services persist state (local dev)
# Each peer writes to `$QUANTIAN_DATA_DIR/<service_name>/state.json`
# ======================================================================
QUANTIAN_DATA_DIR=./data/runtime

# ======================================================================
# Peer-to-peer discovery
# ======================================================================
REGISTRY_URL=http://localhost:8000
LEDGER_URL=http://localhost:8000   # defaults to REGISTRY_URL if unset
HEARTBEAT_INTERVAL_SECONDS=15
REQUEST_TIMEOUT_SECONDS=2.5
LEDGER_VERIFY_INTERVAL_SECONDS=60  # auto-walk the hash chain this often

# ======================================================================
# IoT layer
# ======================================================================
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPICS=quantian/market/+/+    # comma-separated, passed to iot bridge
AWS_INGESTION_URL=http://localhost:8001  # bridge forwards valid messages here

# ======================================================================
# Per-service bind host/port (all optional; defaults to 0.0.0.0 + service default)
# Uppercase service prefix form takes precedence over SERVICE_PORT
# ======================================================================
SERVICE_HOST=0.0.0.0

REGISTRY_SERVICE_PORT=8000
REGISTRY_SERVICE_BASE_URL=http://localhost:8000

AWS_INGESTION_PORT=8001
AWS_INGESTION_BASE_URL=http://localhost:8001

AZURE_ANOMALY_PORT=8002
AZURE_ANOMALY_BASE_URL=http://localhost:8002

GCP_RISK_PORT=8003
GCP_RISK_BASE_URL=http://localhost:8003

IOT_BRIDGE_PORT=8004
IOT_BRIDGE_BASE_URL=http://localhost:8004

# ======================================================================
# Dashboards — where the UIs look for service endpoints
# ======================================================================
# Streamlit reads these directly
AZURE_ANOMALY_URL=http://localhost:8002
GCP_RISK_URL=http://localhost:8003
IOT_BRIDGE_URL=http://localhost:8004

# React dashboard uses a Vite dev-proxy (see web_dashboard/vite.config.ts);
# override the base URL only if serving over the network:
# VITE_DASHBOARD_URL=http://127.0.0.1:5174

# ======================================================================
# Persistence backends (used by the Azure peer in cloud mode)
# ======================================================================
STORAGE_BACKEND=memory             # memory | file | azure_blob

# Azure Blob Storage (only needed when STORAGE_BACKEND=azure_blob)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=quantian-state
AZURE_BLOB_PREFIX=azure_anomaly

# ======================================================================
# Simulator
# ======================================================================
SIMULATOR_SEED=42
